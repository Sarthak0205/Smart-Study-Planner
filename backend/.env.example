# Environment Mode (production, development, test)
NODE_ENV=development

# Port the backend listens on (Render automatically sets PORT in production)
PORT=8000

# Database URL. Critical: Use the Connection String format for Neon PostgreSQL in hosted environments.
# Note: For production on Render connecting to Neon, make sure this starts with postgres:// or postgresql://
# DATABASE_URL=postgres://user:password@ep-xxxx-xxxx.us-east-2.aws.neon.tech/studyflow?sslmode=require
DB_HOST=localhost
DB_PORT=5432
DB_NAME=studyplanner
DB_USER=sdc
DB_PASSWORD=

# Database Connection Pool Settings
DB_POOL_MAX=10
DB_POOL_MIN=0
DB_POOL_IDLE_MS=10000
DB_POOL_ACQUIRE_MS=30000

# Logging level
LOG_LEVEL=info
SLOW_QUERY_MS=150
SLOW_REQUEST_MS=1000

# CORS Allowed Origins.
# Critical: Set this to your frontend URL in production (e.g. https://studyflow.vercel.app).
# For multiple domains, separate by commas without spaces.
CORS_ORIGIN=http://localhost:3000,http://localhost:5173,http://127.0.0.1:5173,http://127.0.0.1:5500

# Express settings
REQUEST_BODY_LIMIT=1mb
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX=20

# JWT Security.
# Critical: You MUST generate long, secure random secrets in production (e.g. using 'openssl rand -hex 64').
JWT_ACCESS_SECRET=replace-with-strong-access-secret
JWT_REFRESH_SECRET=replace-with-strong-refresh-secret
JWT_ACCESS_EXPIRES_IN=15m
REFRESH_TOKEN_DAYS=30
REFRESH_COOKIE_NAME=acadence_refresh_token
